# LLM Provider: openai, anthropic, ollama, gemini
ETHIBENCH_LLM_PROVIDER=openai
ETHIBENCH_LLM_MODEL=gpt-5.4-mini
ETHIBENCH_TEMPERATURE=0.3
# ETHIBENCH_API_URL=          # Custom API endpoint (for Ollama or compatible APIs)
ETHIBENCH_CONCURRENCY=50
ETHIBENCH_MAX_RETRIES=5

# API Keys (set the one matching your provider)
#ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GEMINI_API_KEY=
